# Direct Postgres connection used by scripts/migrate-sheets-to-supabase.mjs.
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Used by scripts/verify-migration.mjs to smoke-test the Edge Function.
IERNE_API_URL=https://YOUR_PROJECT_REF.functions.supabase.co/ierne-api

# Admin POST actions (adminLogin, upsert*, etc.): set IERNE_ADMIN_SECRET in the
# Supabase Dashboard → Edge Functions → ierne-api → Secrets (not required for read-only GETs).

# Source Google Sheet (published to web). Defaults match the existing sheet.
